{
	"name": "dcx-benchmark-luxe-theme",
	"version": "1.0.3",
	"description": "Thème WordPress FSE DCX Benchmark Luxe",
	"author": "Rhapsodies Conseil",
	"private": true,
	"license": "GPL-2.0-or-later",
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@wordpress/browserslist-config": "^6.34.0",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"cssnano": "^7.1.2"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"build": "postcss style.css --use cssnano -o style.min.css --no-map",
		"watch": "postcss style.css --use cssnano -o style.min.css --no-map --watch",
		"changeset": "changeset",
		"version": "changeset version && node scripts/sync-version.mjs",
		"release": "echo \"No build step required\""
	}
}
